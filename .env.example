# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...  # только на сервере, никогда не коммитить

# === RouterAI (LLM) ===
ROUTERAI_API_KEY=rai_xxxxx
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
# Имена моделей в формате "provider/model" — см. https://routerai.ru/models
ROUTERAI_ROUTER_MODEL=deepseek/deepseek-v3.2
ROUTERAI_MAIN_MODEL=anthropic/claude-sonnet-4.6
ROUTERAI_EMBEDDING_MODEL=google/gemini-embedding-2-preview
# Целевая размерность вектора — должна совпадать с vector(N) в миграции БД (1536)
ROUTERAI_EMBEDDING_DIM=1536

# === Email (Postmark) ===
POSTMARK_API_KEY=xxxx
POSTMARK_FROM_EMAIL=hello@offi.ai

# === Telegram ===
TELEGRAM_BOT_TOKEN=xxxx:xxxx

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
